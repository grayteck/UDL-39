name: Stream Zip Splitter

on:
  workflow_dispatch:
    inputs:
      url:
        description: "File URL"
        required: true
      password:
        description: "Zip password (optional)"
        required: false
        default: ""
        type: string

jobs:
  download_and_zip:
    runs-on: ubuntu-latest
    timeout-minutes: 360

    permissions:
      contents: write

    steps:
      - name: Checkout
        uses: actions/checkout@v5

      - name: Install tools
        run: |
          sudo apt update
          sudo apt install -y curl zip p7zip-full

      - name: Prepare directories
        run: |
          mkdir -p downloads
          mkdir -p tmp_parts

      - name: Get filename from URL
        id: get_filename
        run: |
          URL="${{ github.event.inputs.url }}"
          # Try to extract filename from Content-Disposition header
          FILENAME=$(curl -sI "$URL" | grep -i 'Content-Disposition:' | sed -n 's/.*filename=*\([^"]*\).*/\1/p' | tr -d ';\r\n')
          # Fallback to extracting from URL
          if [ -z "$FILENAME" ]; then
            FILENAME=$(basename "$URL" | cut -d'?' -f1)
          fi
          # Sanitize filename to remove potentially problematic characters for git/filesystem
          CLEAN_FILENAME=$(echo "$FILENAME" | sed 's/[^a-zA-Z0-9._-]/_/g')
          echo "Determined filename: $FILENAME"
          echo "Cleaned filename: $CLEAN_FILENAME"
          echo "filename=$CLEAN_FILENAME" >> $GITHUB_OUTPUT

      - name: Stream download and split into parts
        run: |
          URL="${{ github.event.inputs.url }}"
          FILENAME="${{ steps.get_filename.outputs.filename }}"
          PART_PREFIX="downloads/$FILENAME.part."
          MAX_PART_SIZE=95M # 95MB per part

          echo "Streaming download of $FILENAME and splitting into parts..."
          echo "Part prefix: $PART_PREFIX"

          # Stream download and pipe directly to split
          # -L follows redirects
          # -o specifies output file pattern
          curl -L "$URL" | split -b "$MAX_PART_SIZE" - "$PART_PREFIX"

          echo "Splitting complete. Parts created in downloads/ directory."
          ls -lh downloads/

      - name: Zip all parts
        run: |
          PASSWORD="${{ github.event.inputs.password }}"
          ARCHIVE_NAME="archive_${{ steps.get_filename.outputs.filename }}.zip"

          echo "Zipping all parts into $ARCHIVE_NAME..."

          if [ -n "$PASSWORD" ]; then
            echo "Using password."
            # Use zip -r to add all files recursively, -P for password
            # Ensure all files in downloads/ are zipped
            zip -r -P "$PASSWORD" "$ARCHIVE_NAME" downloads/*
          else
            echo "No password provided."
            zip -r "$ARCHIVE_NAME" downloads/*
          fi

          echo "Zipping complete."
          ls -lh "$ARCHIVE_NAME"

          # Clean up the individual parts
          echo "Cleaning up individual parts..."
          rm -rf downloads/*

          # Move the final zip archive to the root for easier commit
          mv "$ARCHIVE_NAME" .

      - name: Commit zip file
        run: |
          git config user.name github-actions
          git config user.email github-actions@github.com

          ARCHIVE_NAME="archive_${{ steps.get_filename.outputs.filename }}.zip"

          # Check if the zip file exists before trying to add/commit
          if [ -f "$ARCHIVE_NAME" ]; then
            git add "$ARCHIVE_NAME"
            git commit -m "Downloaded and zipped: ${{ steps.get_filename.outputs.filename }}"
            git push
            echo "Zip file committed and pushed."
          else
            echo "Error: Zip file '$ARCHIVE_NAME' not found after zipping. Cannot commit."
            exit 1
          fi

      - name: Show download link for the zip file
        run: |
          REPO="${{ github.repository }}"
          ARCHIVE_NAME="archive_${{ steps.get_filename.outputs.filename }}.zip"
          echo "Download link for the zip archive:"
          echo "https://raw.githubusercontent.com/$REPO/main/$ARCHIVE_NAME"
